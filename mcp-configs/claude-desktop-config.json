{
  "mcpServers": {
    "rolldice": {
      "command": "node",
      "args": ["C:\\path\\to\\mcp\\servers\\rolldice\\dist\\server.js"]
    },
    "bootcamp-ai-agent": {
      "command": "npx",
      "args": ["bootcamp-ai-agent-server"]
    },
    "calendar-booking": {
      "command": "npx",
      "args": ["calendar-booking-mcp"]
    },
    "github": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "your_token_here"
      }
    }
  }
}